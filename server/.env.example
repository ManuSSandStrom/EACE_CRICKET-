PORT=5000

# CORS — set to your Netlify URL in production
CLIENT_URL=https://your-netlify-url.netlify.app
CLIENT_URLS=https://your-netlify-url.netlify.app

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/dbname

# JWT secret — use a strong random string in production
JWT_SECRET=replace-with-strong-secret

# Admin credentials
ADMIN_EMAIL=admin@eace.in
ADMIN_PASSWORD=your_admin_password

# OpenAI / OpenRouter for AI assistant
OPENAI_API_KEY=your-api-key
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=openai/gpt-4o-mini

# Contact information
CONTACT_PHONE=9515022680
CONTACT_EMAIL=your_email@example.com
